@model Paged<Movie>

<partial name="_BreadCrumbs" model=@(new [] {
    ("/","Home"),
    ("","Movies")
}) />

<div class="card border rounded shadow p-4">

    <!-- Title bar -->
    <div class="border-bottom d-flex align-items-center justify-content-between">
        <h3 class="text-primary">Movie List</h3>
        <a asp-condition=@User.IsInRole("admin") class="btn btn-light" asp-action="create" title="add movie" aria-label="add movie">
            <i class="bi bi-plus"></i> Create
        </a>
    </div>

    <!-- List of movies -->
    <table class="table table-hover mt-4">
        <thead>
            <tr>
                <th>
                    Id
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="id" asp-route-direction="asc">
                        <i class="bi bi-caret-up"/></i>
                    </a>
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="id" asp-route-direction="desc">
                        <i class="bi bi-caret-down"></i>
                    </a>
                </th>
                <th>
                    Title
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Title" asp-route-direction="asc">
                        <i class="bi bi-caret-up"/></i>
                    </a>
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Title" asp-route-direction="desc">
                        <i class="bi bi-caret-down"></i>
                    </a>                   
                </th>
                <th>
                    Director
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Director" asp-route-direction="asc">
                        <i class="bi bi-caret-up"/></i>
                    </a>
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Director" asp-route-direction="desc">
                        <i class="bi bi-caret-down"></i>
                    </a>
                </th>
                <th>
                   Genre
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Genre" asp-route-direction="asc">
                        <i class="bi bi-caret-up"/></i>
                    </a>
                    <a class="btn btn-link p-0" asp-action="Index" asp-route-orderBy="Genre" asp-route-direction="desc">
                        <i class="bi bi-caret-down"></i>
                    </a>
                </th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var m in Model.Data)
            {
                <tr>
                    <td>@m.Id</td>
                    <td>@m.Title</td>
                    <td>@m.Director</td>
                    <td>@m.Genre</td>
                    <td class="text-end">                      
                        <a asp-action="Details" asp-route-id=@m.Id>
                            <i class="bi bi-display-fill me-2" title="view movie" arial-label="view movie"></i>
                        </a>
                                           
                        <a asp-condition=@User.HasOneOfRoles("admin,support") asp-action="Edit" asp-route-id=@m.Id>
                            <i class="bi bi-pencil-fill me-2" title="edit movie" aria-label="edit movie"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <vc:paginator action="Index" rows=@Model.TotalRows pages=@Model.TotalPages current=@Model.CurrentPage size=@Model.PageSize  />

</div>
